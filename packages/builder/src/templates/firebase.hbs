import { initializeApp } from "firebase/app";
import { getFirestore{{#if firestoreConfig.ignoreUndefinedProperties}}, initializeFirestore{{/if}} } from "firebase/firestore";
import { getAuth } from "firebase/auth";

const firebaseConfig = {
  {{#each firebaseConfig}}
    {{name}}: "{{value}}",
  {{/each}}
};

export const app = initializeApp(firebaseConfig);
{{#if firestoreConfig.ignoreUndefinedProperties}}
export const db = initializeFirestore(app, { ignoreUndefinedProperties: true }{{#if firestoreConfig.databaseId}}, "{{firestoreConfig.databaseId}}"{{/if}});
{{else}}
